# API Configuration
# In development, leave these empty to use the Vite proxy (recommended).
# In production, set these to the full backend URLs.
# VITE_API_BASE_URL=https://your-api.example.com/api
# VITE_WS_URL=wss://your-api.example.com/ws

# App Configuration
VITE_APP_NAME=ChatApp
VITE_APP_VERSION=1.0.0

# Token Configuration
VITE_REFRESH_TOKEN_KEY=chatapp_refresh_token
